# =============================================================================
# Repo-root .env.example
# =============================================================================
# Per-app environment variables live next to each app, e.g.
# `apps/desktop/.env.example`. Anything cross-app (CI, multi-provider model
# config, gateway secrets used by both daemon + desktop) belongs here.
#
# All variables are OPTIONAL — the apps work without them.
# =============================================================================

# ---- AI provider keys (used only when running providers directly, not via the
# bundled CLI binaries that the desktop app downloads). ----
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...        # Codex CLI / OpenAI models
# GEMINI_API_KEY=...           # Google Gemini, if used

# ---- Gateway (apps/gateway, ASP.NET Core) ----
# ASPNETCORE_ENVIRONMENT=Development
# ASPNETCORE_URLS=http://localhost:5111

# ---- Daemon (apps/daemon, Go) ----
# CHURRO_DAEMON_LOG_LEVEL=info
